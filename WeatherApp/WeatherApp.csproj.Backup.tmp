<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="BlazorApp21.Api\**" />
		<Content Remove="BlazorApp21.Api\**" />
		<EmbeddedResource Remove="BlazorApp21.Api\**" />
		<None Remove="BlazorApp21.Api\**" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="9.0.2" />
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="9.0.2" PrivateAssets="all" />
		<PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
		<PackageReference Include="MongoDB.Bson" Version="3.8.1" />
		<PackageReference Include="MongoDB.Driver" Version="3.8.1" />
		<PackageReference Include="MudBlazor" Version="9.4.0" />
		<PackageReference Include="Supabase" Version="1.1.1" />
		<PackageReference Include="Swashbuckle.AspNetCore" Version="10.2.1" />
		<PackageReference Include="Swashbuckle.AspNetCore.Swagger" Version="10.2.1" />
	</ItemGroup>
</Project>
