@page "/signup"
@using WeatherApp.Services
@inject WeatherApp.Services.SupabaseService supabaseService
@inject NavigationManager nav

<div style="
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
    background:@(ThemeState.IsDark
                  ? "linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)"
                  : "linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 50%, #f5f5f5 100%)");">

    <div style="
        background:@(ThemeState.IsDark ? "#1e1e2e" : "white");
        color:@(ThemeState.IsDark ? "#e0e0e0" : "#1a1a1a");
        padding:36px;
        border-radius:16px;
        width:340px;
        text-align:center;
        box-shadow:@(ThemeState.IsDark
                              ? "0 8px 32px rgba(0,0,0,0.5)"
                              : "0 8px 32px rgba(0,0,0,0.10)");
        border:1px solid @(ThemeState.IsDark ? "#333355" : "#e0e0e0");">

        <h3 style="margin-bottom:20px; font-weight:700;">
            🌤️ Create Account
        </h3>

        <input @bind="email"
               placeholder="Email"
               style="
                   width:100%;
                   padding:10px;
                   margin-bottom:12px;
                   border-radius:8px;
                   border:1px solid @(ThemeState.IsDark ? "#444466" : "#ccc");
                   background:@(ThemeState.IsDark ? "#2a2a3e" : "#f9f9f9");
                   color:@(ThemeState.IsDark ? "#e0e0e0" : "#1a1a1a");
                   font-size:0.95rem;
                   box-sizing:border-box;" />

        <input @bind="password"
               type="password"
               placeholder="Password"
               style="
                   width:100%;
                   padding:10px;
                   margin-bottom:18px;
                   border-radius:8px;
                   border:1px solid @(ThemeState.IsDark ? "#444466" : "#ccc");
                   background:@(ThemeState.IsDark ? "#2a2a3e" : "#f9f9f9");
                   color:@(ThemeState.IsDark ? "#e0e0e0" : "#1a1a1a");
                   font-size:0.95rem;
                   box-sizing:border-box;" />

        <button @onclick="HandleRegister"
                disabled="@isLoading"
                style="
                    width:100%;
                    padding:11px;
                    background-color:#5c6bc0;
                    color:white;
                    border:none;
                    border-radius:8px;
                    cursor:pointer;
                    font-size:1rem;
                    font-weight:600;
                    letter-spacing:0.5px;">
            @(isLoading ? "Registering..." : "Register")
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <p style="margin-top:12px; color:@(message.Contains("success") ? "#4caf50" : "#f44336");">
                @message
            </p>
        }

        <hr style="border-color:@(ThemeState.IsDark ? "#333355" : "#e0e0e0"); margin:16px 0;" />

        <p style="font-size:0.9rem;">
            Already have an account?
            <a href="login" style="color:#5c6bc0; font-weight:600;">Login</a>
        </p>
    </div>
</div>

@code {
    string email = "";
    string password = "";
    string message = "";
    bool isLoading = false;

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            message = "Please enter email and password!";
            return;
        }

        isLoading = true;
        message = "";
        StateHasChanged();

        try
        {
            bool ok = await supabaseService.SignUp(email, password);
            if (ok)
            {
                message = "Registered successfully!";
                await Task.Delay(800);
                nav.NavigateTo("/login");
            }
            else
            {
                message = "Email already exists!";
            }
        }
        catch (Exception ex)
        {
            message = "Registration failed: " + ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
