@using Microsoft.AspNetCore.Components

<div class="card">
    <h3>@Name</h3>
    <p>Department: @Department</p>
    <p>Age: @Age</p>
</div>

@code {
    [Parameter]
    public string Name { get; set; }

    [Parameter]
    public string Department { get; set; }

    [Parameter]
    public int Age { get; set; }
}